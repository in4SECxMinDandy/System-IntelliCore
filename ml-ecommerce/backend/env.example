# ==========================================
# IntelliCore Backend - Environment Configuration
# ==========================================
# Copy this file to .env and update values for your environment
# Database connection required for backend to start

# Server Configuration
NODE_ENV=development
PORT=4000

# PostgreSQL Database (REQUIRED - Backend will crash without this)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass@localhost:5432/ecommerce

# MongoDB (Event Logs & Analytics)
# Format: mongodb://username:password@host:port/database?authSource=admin
MONGODB_URI=mongodb://mongo_user:mongo_pass@localhost:27017/ecommerce_events?authSource=admin

# Redis (Cache & Session)
# Format: redis://:password@host:port
REDIS_URL=redis://:redis_pass@localhost:6379

# JWT Configuration (REQUIRED for authentication)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ML Service URL (for recommendation endpoints)
ML_SERVICE_URL=http://localhost:8001

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:3000

# Stripe Payment Integration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=noreply@intellicore.shop

# Optional: OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Optional: Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
