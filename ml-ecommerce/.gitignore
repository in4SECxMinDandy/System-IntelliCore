# ==========================================
# .gitignore — ML Ecommerce
# ==========================================

# Environment files
!.env.example
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js
frontend/.next/
frontend/out/
frontend/build/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
ml-service/venv/
ml-service/.venv/
ml-service/env/
ml-service/.env/
*.egg-info/
dist/
build/
.eggs/

# ML Models (large binary files)
ml-service/models/*.pkl
ml-service/models/*.pt
ml-service/models/*.pth
ml-service/models/*.bin
!ml-service/models/.gitkeep

# MLflow
mlruns/
mlartifacts/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# Docker
.docker/

# Database
*.sql.bak
pgdata/
mongodata/
redisdata/

# Logs
logs/
*.log

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# Testing
coverage/
.nyc_output/
.pytest_cache/
htmlcov/

# Prisma
backend/prisma/migrations/

# Uploads
backend/uploads/
