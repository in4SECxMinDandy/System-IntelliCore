# ==========================================
# IntelliCore ML Ecommerce - Environment Variables
# ==========================================

# Database
DB_USER=ecommerce_user
DB_PASS=ecommerce_pass

# Redis
REDIS_PASSWORD=redis_pass

# MongoDB
MONGO_USER=mongo_user
MONGO_PASS=mongo_pass

# JWT Secrets (IMPORTANT: Change these in production!)
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_REFRESH_SECRET=super_secret_refresh_key_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=http://localhost:3000

# API URLs
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ML_URL=http://localhost:8001

# Stripe (Use test keys for development)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@intellicore.shop

# ML Service
RETRAIN_INTERVAL_HOURS=24

# Grafana
GRAFANA_USER=admin
GRAFANA_PASS=admin123
