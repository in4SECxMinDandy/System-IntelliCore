# ==========================================
# IntelliCore ML Ecommerce — Environment Variables v2
# Copy this file to .env and fill in your values
# ==========================================

# ==========================================
# DATABASE
# ==========================================
DB_USER=ecommerce_user
DB_PASS=ecommerce_pass_change_me
DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass_change_me@localhost:5432/ecommerce

# ==========================================
# REDIS
# ==========================================
REDIS_PASSWORD=redis_pass_change_me
REDIS_URL=redis://:redis_pass_change_me@localhost:6379

# ==========================================
# MONGODB
# ==========================================
MONGO_USER=mongo_user
MONGO_PASS=mongo_pass_change_me
MONGODB_URI=mongodb://mongo_user:mongo_pass_change_me@localhost:27017/ecommerce_events?authSource=admin

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# STRIPE PAYMENT
# ==========================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ==========================================
# EMAIL (SMTP)
# ==========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@intellicore.shop

# ==========================================
# FRONTEND
# ==========================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_ML_URL=http://localhost:8001

# ==========================================
# ML SERVICE
# ==========================================
MLFLOW_TRACKING_URI=http://localhost:5000
MODEL_DIR=./models
RETRAIN_INTERVAL_HOURS=24

# ==========================================
# MONITORING
# ==========================================
GRAFANA_USER=admin
GRAFANA_PASS=admin123_change_me

# ==========================================
# THIRD-PARTY INTEGRATIONS (Optional)
# ==========================================

# Shipping API (e.g., ShipStation, EasyPost)
SHIPPING_API_KEY=
SHIPPING_API_URL=

# CRM Integration (e.g., HubSpot, Salesforce)
CRM_API_KEY=
CRM_API_URL=

# Google Analytics
NEXT_PUBLIC_GA_ID=

# Sentry Error Tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_2FA=true
ENABLE_COMMUNITY=true
ENABLE_CHATBOT=true
ENABLE_STRIPE=true
ENABLE_PAYPAL=false
ENABLE_INVENTORY_ALERTS=true
LOW_STOCK_THRESHOLD=10

# ==========================================
# LOCALIZATION
# ==========================================
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=USD
SUPPORTED_LANGUAGES=en,vi,zh,ja,ko
SUPPORTED_CURRENCIES=USD,EUR,GBP,VND,JPY

# ==========================================
# SECURITY
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_change_me
