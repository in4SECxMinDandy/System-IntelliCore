# ==========================================
# Database
# ==========================================
DB_USER=ecommerce_user
DB_PASS=ecommerce_pass_change_me
DATABASE_URL=postgresql://ecommerce_user:ecommerce_pass_change_me@localhost:5432/ecommerce

# ==========================================
# Redis
# ==========================================
REDIS_PASSWORD=redis_pass_change_me
REDIS_URL=redis://:redis_pass_change_me@localhost:6379

# ==========================================
# MongoDB
# ==========================================
MONGO_USER=mongo_user
MONGO_PASS=mongo_pass_change_me
MONGODB_URI=mongodb://mongo_user:mongo_pass_change_me@localhost:27017/ecommerce_events?authSource=admin

# ==========================================
# JWT
# ==========================================
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars_change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# App
# ==========================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
ML_SERVICE_URL=http://localhost:8001

# ==========================================
# MLflow
# ==========================================
MLFLOW_TRACKING_URI=http://localhost:5000

# ==========================================
# Grafana
# ==========================================
GRAFANA_USER=admin
GRAFANA_PASS=admin123_change_me

# ==========================================
# File Upload (Cloudinary)
# ==========================================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==========================================
# Email (SendGrid)
# ==========================================
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com
